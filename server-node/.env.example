NODE_ENV=development
PORT=4000

# Admin credentials
ADMIN_USERNAME=admin_username_here
ADMIN_PASSWORD=admin_password_here
ADMIN_TOKEN=admin_token_here
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
SUPABASE_STORAGE_BUCKET=cms-uploads

# Optional direct DB connection
DATABASE_URL=postgresql://drawndimension_app:DrawnDB2026Safe_91@127.0.0.1:5432/drawndimension_db
DATABASE_SSL=false

# SMTP (required for signup notifications, employee welcome emails, and work assignment emails)
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@your-domain.com
SMTP_PASS=your_smtp_password_or_api_key
SMTP_FROM="Your Company <info@your-domain.com>"
OFFICIAL_NOTIFICATION_EMAIL=team@your-domain.com
CONTACT_FORM_NOTIFICATION_EMAIL=team@your-domain.com
LIVE_CHAT_NOTIFICATION_EMAIL=team@your-domain.com

# Branding in emails
SITE_BASE_URL=https://your-domain.com
# Optional override for logo URL in emails. Defaults to SITE_BASE_URL + /images/logo.png
BRAND_LOGO_URL=https://your-domain.com/images/logo.png

# CORS (comma-separated for multiple)
CORS_ORIGIN=https://your-domain.com,https://www.your-domain.com,http://localhost:8080,http://127.0.0.1:8080,http://localhost:8081,http://127.0.0.1:8081
